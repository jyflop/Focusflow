rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Master Overrides (Catch-all)
    // ===============================================================
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == "5DpJouFlgDSAQmq4dIjO173bKjD3" || 
        request.auth.token.email == "jyflopkaw@gmail.com" ||
        request.auth.token.email == "swartselsa0@gmail.com" ||
        request.auth.token.email == "louwhenleo@gmail.com"
      );
    }
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: /users/{userId}/projects/{projectId}
    // Fields: id, name, description, startDate, endDate, status, progress, createdAt, updatedAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}
    // Fields: id, projectId, name, description, startDate, dueDate, priority, status, progress, order, totalTimeSpent, createdAt, updatedAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}/milestones/{milestoneId}
    // Fields: id, taskId, name, completed, order, createdAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}/timeLogs/{logId}
    // Fields: id, taskId, duration, startTime, endTime
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "jyflopkaw@gmail.com" ||
        request.auth.token.email == "swartselsa0@gmail.com" ||
        request.auth.token.email == "louwhenleo@gmail.com" ||
        request.auth.uid == "5DpJouFlgDSAQmq4dIjO173bKjD3" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Member').lower() == 'admin')
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserProfile(data, userId) {
      // For creation, require uid and email. For update, just ensure they match if present.
      return (!('uid' in data) || data.get('uid', '') == userId) &&
             (!('email' in data) || (data.get('email', '') is string && data.get('email', '').size() <= 255)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('role' in data) || (data.role.lower() in ['admin', 'member'])) &&
             (!('position' in data) || (data.position is string && data.position.size() <= 100)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == null));
    }

    function isValidProject(data) {
      return hasRequiredFields(['name', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.status in ['Active', 'Completed', 'On Hold'];
    }

    function isValidTask(data) {
      return hasRequiredFields(['name', 'priority', 'status', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.priority in ['Low', 'Medium', 'High'] &&
             data.status in ['Not Started', 'In Progress', 'Completed'] &&
             data.order is number;
    }

    function isValidMilestone(data) {
      return hasRequiredFields(['name', 'completed', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.completed is bool &&
             data.order is number;
    }

    function isValidTimeLog(data) {
      return hasRequiredFields(['duration', 'startTime', 'endTime']) &&
             data.duration is number &&
             data.startTime is string &&
             data.endTime is string;
    }

    function isValidInvitation(data) {
      return hasRequiredFields(['email', 'senderId', 'senderName', 'status']) &&
             data.email is string &&
             data.senderId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'declined'];
    }

    function isProjectAdmin(projectId) {
      let project = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isAdmin() || project.ownerId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.token.email == resource.data.email || request.auth.uid == resource.data.senderId);
      allow create: if isAuthenticated() && isValidInvitation(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.email || request.auth.uid == resource.data.senderId);
    }

    match /conversations/{convId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated() && 
                     request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
                     request.resource.data.senderId == request.auth.uid;
      }
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.get('participants', []) || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && request.resource.data.get('ownerId', '') == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.get('participants', [])) && (
        // Restrict sensitive fields to owner/admin
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants', 'ownerId', 'assigneeId']) ||
        isAdmin() || resource.data.ownerId == request.auth.uid
      );
      allow delete: if isAuthenticated() && (
        isAdmin() || 
        resource.data.get('ownerId', '') == request.auth.uid
      );

      match /tasks/{taskId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin()) && isValidTask(request.resource.data);
        allow update: if isAuthenticated() && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', [])) && (
          // Restrict assignee removal/change to creator or project admin
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['assigneeId', 'creatorId']) ||
          isAdmin() || 
          resource.data.get('creatorId', '') == request.auth.uid ||
          get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
        );
        allow delete: if isAuthenticated() && (
          isAdmin() || 
          resource.data.get('creatorId', '') == request.auth.uid
        );

        match /milestones/{milestoneId} {
          allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
          allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin()) && isValidMilestone(request.resource.data);
          allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
          allow delete: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
        }

        match /timeLogs/{logId} {
          allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
          allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin()) && isValidTimeLog(request.resource.data);
          allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
          allow delete: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.get('participants', []) || isAdmin());
        }
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data, userId);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUserProfile(request.resource.data, userId) &&
                    (isAdmin() || areFieldsUnchanged(['role']));
      allow delete: if request.auth != null && (
        request.auth.token.email == "jyflopkaw@gmail.com" ||
        request.auth.token.email == "swartselsa0@gmail.com" ||
        request.auth.token.email == "louwhenleo@gmail.com" ||
        request.auth.uid == "5DpJouFlgDSAQmq4dIjO173bKjD3" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'Member').lower() == 'admin')
      );

      match /projects/{projectId} {
        allow read, write: if isOwner(userId) || isAdmin();

        match /tasks/{taskId} {
          allow read, write: if isOwner(userId) || isAdmin();

          match /milestones/{milestoneId} {
            allow read, write: if isOwner(userId) || isAdmin();
          }

          match /timeLogs/{logId} {
            allow read, write: if isOwner(userId) || isAdmin();
          }
        }
      }
    }
  }
}
