rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: /users/{userId}/projects/{projectId}
    // Fields: id, name, description, startDate, endDate, status, progress, createdAt, updatedAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}
    // Fields: id, projectId, name, description, startDate, dueDate, priority, status, progress, order, totalTimeSpent, createdAt, updatedAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}/milestones/{milestoneId}
    // Fields: id, taskId, name, completed, order, createdAt
    //
    // Collection: /users/{userId}/projects/{projectId}/tasks/{taskId}/timeLogs/{logId}
    // Fields: id, taskId, duration, startTime, endTime
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Admin', 'admin'] ||
          (request.auth.token.email == "jyflopkaw@gmail.com" && (request.auth.token.email_verified == true || request.auth.token.email_verified == false)));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserProfile(data, userId) {
      return hasRequiredFields(['uid', 'email']) &&
             data.uid == userId &&
             data.email is string && data.email.size() <= 255 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('role' in data) || (data.role in ['Admin', 'Member', 'admin', 'member'])) &&
             (!('position' in data) || (data.position is string && data.position.size() <= 100)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == null));
    }

    function isValidProject(data) {
      return hasRequiredFields(['name', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.status in ['Active', 'Completed', 'On Hold'];
    }

    function isValidTask(data) {
      return hasRequiredFields(['name', 'priority', 'status', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.priority in ['Low', 'Medium', 'High'] &&
             data.status in ['Not Started', 'In Progress', 'Completed'] &&
             data.order is number;
    }

    function isValidMilestone(data) {
      return hasRequiredFields(['name', 'completed', 'order']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.completed is bool &&
             data.order is number;
    }

    function isValidTimeLog(data) {
      return hasRequiredFields(['duration', 'startTime', 'endTime']) &&
             data.duration is number &&
             data.startTime is string &&
             data.endTime is string;
    }

    function isValidInvitation(data) {
      return hasRequiredFields(['email', 'senderId', 'senderName', 'status']) &&
             data.email is string &&
             data.senderId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'declined'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (request.auth.token.email == resource.data.email || request.auth.uid == resource.data.senderId);
      allow create: if isAuthenticated() && isValidInvitation(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.token.email == resource.data.email || request.auth.uid == resource.data.senderId);
    }

    match /conversations/{convId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuthenticated() && 
                     request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
                     request.resource.data.senderId == request.auth.uid;
      }
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isAdmin());
      allow delete: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || isAdmin());

      match /tasks/{taskId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin()) && isValidTask(request.resource.data);
        allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
        allow delete: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());

        match /milestones/{milestoneId} {
          allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
          allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin()) && isValidMilestone(request.resource.data);
          allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
          allow delete: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
        }

        match /timeLogs/{logId} {
          allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
          allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin()) && isValidTimeLog(request.resource.data);
          allow update: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
          allow delete: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.participants || isAdmin());
        }
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data, userId);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUserProfile(request.resource.data, userId) &&
                    (isAdmin() || areFieldsUnchanged(['role']));
    }
  }
}
